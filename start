#!/usr/bin/env bash
set -euo pipefail

# When this image is launched by JupyterHub, run the single-user server.
if [[ -n "${JUPYTERHUB_API_TOKEN:-}" || -n "${JPY_API_TOKEN:-}" ]]; then
  # repo2docker defaults to `jupyter notebook ...`; strip that command prefix
  # and pass through only the effective server flags.
  if [[ "$#" -ge 2 && "$1" == "jupyter" && ( "$2" == "notebook" || "$2" == "lab" ) ]]; then
    shift 2
  fi
  exec jupyterhub-singleuser "$@"
fi

exec "$@"
